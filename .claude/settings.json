{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Bash(pnpm:*)",
			"Bash(git:*)",
			"Bash(ls:*)",
			"Bash(mkdir:*)",
			"Bash(tree:*)",
			"Bash(echo:*)",
		],
		"deny": [
			"Read(.env*)"
		],
		"ask": [
			"Bash(rm -rf:*)",
			"Bash(mv:*)"
		]
	}
}
